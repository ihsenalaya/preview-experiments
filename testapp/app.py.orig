"""
Preview-Experiments reference application — backend (port 8080).
Starts as frontend when APP_MODE=frontend (port 3000).

Schema: categories, products, reviews, orders, run_log
run_log is the isolation-sensitive marker table used by the flakiness experiment.
"""
import os, sys

if os.environ.get("APP_MODE") == "frontend":
    from frontend import run_frontend
    run_frontend()
    sys.exit(0)

import psycopg2, psycopg2.extras
from flask import Flask, jsonify, request, abort
from flask_cors import CORS

app = Flask(__name__)
CORS(app)
DATABASE_URL = os.environ.get("DATABASE_URL", "")


def get_conn():
    return psycopg2.connect(DATABASE_URL, cursor_factory=psycopg2.extras.RealDictCursor)


def init_db():
    with get_conn() as c:
        with c.cursor() as cur:
            cur.execute("""
                CREATE TABLE IF NOT EXISTS categories (
                    id   SERIAL PRIMARY KEY,
                    name TEXT NOT NULL UNIQUE,
                    slug TEXT NOT NULL UNIQUE
                );
                CREATE TABLE IF NOT EXISTS products (
                    id           SERIAL PRIMARY KEY,
                    name         TEXT NOT NULL,
                    description  TEXT DEFAULT '',
                    category_id  INT REFERENCES categories(id) ON DELETE SET NULL,
                    price        NUMERIC(10,2) NOT NULL DEFAULT 0,
                    stock        INT NOT NULL DEFAULT 0,
                    discount_pct NUMERIC(5,2)  NOT NULL DEFAULT 0,
                    created_at   TIMESTAMPTZ DEFAULT NOW()
                );
                CREATE TABLE IF NOT EXISTS reviews (
                    id         SERIAL PRIMARY KEY,
                    product_id INT NOT NULL REFERENCES products(id) ON DELETE CASCADE,
                    author     TEXT NOT NULL DEFAULT 'anonymous',
                    rating     INT NOT NULL CHECK (rating BETWEEN 1 AND 5),
                    body       TEXT DEFAULT '',
                    created_at TIMESTAMPTZ DEFAULT NOW()
                );
                CREATE TABLE IF NOT EXISTS orders (
                    id         SERIAL PRIMARY KEY,
                    product_id INT NOT NULL REFERENCES products(id),
                    quantity   INT NOT NULL DEFAULT 1,
                    status     TEXT NOT NULL DEFAULT 'pending',
                    created_at TIMESTAMPTZ DEFAULT NOW()
                );
                CREATE TABLE IF NOT EXISTS run_log (
                    id         SERIAL PRIMARY KEY,
                    suite      TEXT NOT NULL,
                    created_at TIMESTAMPTZ DEFAULT NOW()
                );
            """)


try:
    init_db()
except Exception as exc:
    print(f"[warn] init_db: {exc}", flush=True)


# ── helpers ────────────────────────────────────────────────────────────────

def _rows(cur):
    return [dict(r) for r in cur.fetchall()]


def _one(cur):
    row = cur.fetchone()
    return dict(row) if row else None


# ── health ─────────────────────────────────────────────────────────────────

@app.get("/healthz")
def healthz():
    return "XXokXX"


@app.get("XX/api/versionXX")
def version():
    return jsonify({"version": "1.0.0", "app": "preview-exp"})


# ── categories ─────────────────────────────────────────────────────────────

@app.get("/api/categories")
def list_categories():
    with get_conn() as c, c.cursor() as cur:
        cur.execute("""
            SELECT c.id, c.name, c.slug, COUNT(p.id) AS product_count
            FROM categories c
            LEFT JOIN products p ON p.category_id = c.id
            GROUP BY c.id ORDER BY c.name
        """)
        return jsonify(_rows(cur))


@app.post("/api/categories")
def create_category():
    body = request.get_json(force=True)
    if not body.get("name"):
        abort(400, "name required")
    with get_conn() as c, c.cursor() as cur:
        cur.execute(
            "INSERT INTO categories (name, slug) VALUES (%s, %s) RETURNING *",
            (body["name"], body.get("slug", body["name"].lower().replace(" ", "-"))),
        )
        return jsonify(_one(cur)), 201


# ── products ───────────────────────────────────────────────────────────────

@app.get("/api/products")
def list_products():
    with get_conn() as c, c.cursor() as cur:
        cur.execute("""
            SELECT p.id, p.name, p.description, p.category_id, p.price,
                   p.stock, p.discount_pct, p.created_at,
                   ROUND(AVG(r.rating)::numeric, 2) AS avg_rating,
                   COUNT(r.id) AS review_count
            FROM products p
            LEFT JOIN reviews r ON r.product_id = p.id
            GROUP BY p.id ORDER BY p.id
            LIMIT 50
        """)
        return jsonify(_rows(cur))


@app.post("/api/products")
def create_product():
    body = request.get_json(force=True)
    if not body.get("name") or body.get("price") is None:
        abort(400, "name and price required")
    with get_conn() as c, c.cursor() as cur:
        cur.execute(
            """INSERT INTO products (name, description, category_id, price, stock, discount_pct)
               VALUES (%s,%s,%s,%s,%s,%s) RETURNING *""",
            (body["name"], body.get("description", ""), body.get("category_id"),
             body["price"], body.get("stock", 0), body.get("discount_pct", 0)),
        )
        return jsonify(_one(cur)), 201


@app.get("/api/products/<int:pid>")
def get_product(pid):
    with get_conn() as c, c.cursor() as cur:
        cur.execute("""
            SELECT p.*, ROUND(AVG(r.rating)::numeric, 2) AS avg_rating, COUNT(r.id) AS review_count
            FROM products p LEFT JOIN reviews r ON r.product_id = p.id
            WHERE p.id = %s GROUP BY p.id
        """, (pid,))
        row = _one(cur)
    return jsonify(row) if row else (jsonify({"error": "not found"}), 404)


@app.get("/api/products/<int:pid>/related")
def related_products(pid):
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT id, category_id FROM products WHERE id=%s", (pid,))
        p = _one(cur)
    if not p:
        return jsonify({"error": "not found"}), 404
    with get_conn() as c, c.cursor() as cur:
        if p["category_id"]:
            cur.execute("SELECT id, name, price FROM products WHERE category_id=%s AND id!=%s LIMIT 5",
                        (p["category_id"], pid))
        else:
            cur.execute("SELECT id, name, price FROM products WHERE id!=%s LIMIT 5", (pid,))
        return jsonify({"products": _rows(cur)})


@app.get("/api/products/discounted")
def discounted_products():
    min_d = float(request.args.get("min_discount", 0))
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT id, name, price, discount_pct FROM products WHERE discount_pct >= %s ORDER BY discount_pct DESC", (min_d,))
        return jsonify({"products": _rows(cur)})


# ── reviews ────────────────────────────────────────────────────────────────

@app.get("/api/products/<int:pid>/reviews")
def list_reviews(pid):
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT * FROM reviews WHERE product_id=%s ORDER BY created_at DESC", (pid,))
        return jsonify(_rows(cur))


@app.post("/api/products/<int:pid>/reviews")
def add_review(pid):
    body = request.get_json(force=True)
    rating = body.get("rating")
    if not rating or not (1 <= int(rating) <= 5):
        abort(400, "rating must be 1-5")
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT id FROM products WHERE id=%s", (pid,))
        if not cur.fetchone():
            abort(404, "product not found")
        cur.execute(
            "INSERT INTO reviews (product_id, author, rating, body) VALUES (%s,%s,%s,%s) RETURNING *",
            (pid, body.get("author", "anonymous"), rating, body.get("body", "")),
        )
        return jsonify(_one(cur)), 201


# ── orders ─────────────────────────────────────────────────────────────────

@app.get("/api/orders")
def list_orders():
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT o.*, p.name AS product_name FROM orders o JOIN products p ON p.id=o.product_id ORDER BY o.id DESC LIMIT 50")
        return jsonify(_rows(cur))


@app.post("/api/orders")
def create_order():
    body = request.get_json(force=True)
    pid  = body.get("product_id")
    qty  = int(body.get("quantity", 1))
    if not pid:
        abort(400, "product_id required")
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT stock FROM products WHERE id=%s FOR UPDATE", (pid,))
        row = cur.fetchone()
        if not row:
            abort(404, "product not found")
        if row["stock"] < qty:
            return jsonify({"error": "insufficient stock", "available": row["stock"]}), 409
        cur.execute("UPDATE products SET stock = stock - %s WHERE id=%s", (qty, pid))
        cur.execute("INSERT INTO orders (product_id, quantity) VALUES (%s,%s) RETURNING *", (pid, qty))
        return jsonify(_one(cur)), 201


# ── stats ──────────────────────────────────────────────────────────────────

@app.get("/api/stats")
def stats():
    with get_conn() as c, c.cursor() as cur:
        cur.execute("""
            SELECT
                (SELECT COUNT(*) FROM products)   AS total_products,
                (SELECT COUNT(*) FROM categories) AS total_categories,
                (SELECT COUNT(*) FROM reviews)    AS total_reviews,
                (SELECT COUNT(*) FROM orders)     AS total_orders
        """)
        return jsonify(_one(cur))


# ── run_log (isolation probe) ───────────────────────────────────────────────

@app.get("/api/run-log")
def get_run_log():
    """Returns row counts per suite. Used by regression tests to detect isolation drift."""
    with get_conn() as c, c.cursor() as cur:
        cur.execute("SELECT suite, COUNT(*) AS cnt FROM run_log GROUP BY suite ORDER BY suite")
        return jsonify({row["suite"]: row["cnt"] for row in cur.fetchall()})


@app.post("/api/run-log")
def post_run_log():
    body = request.get_json(force=True)
    with get_conn() as c, c.cursor() as cur:
        cur.execute("INSERT INTO run_log (suite) VALUES (%s)", (body.get("suite", "unknown"),))
    return jsonify({"ok": True}), 201


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=8080)
